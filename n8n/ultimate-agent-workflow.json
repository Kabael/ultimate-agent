{
  "name": "Ultimate Agent Platform",
  "nodes": [
    {
      "name": "Когда: Новый клиент",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [250, 300],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes"
            }
          ]
        }
      }
    },
    {
      "name": "Проверить новых клиентов",
      "type": "n8n-nodes-base.httpRequest",
      "position": [450, 300],
      "parameters": {
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer 4555d5bd1f5a136439ed7a785251c29e61a5290bd330d7a4"
            }
          ]
        },
        "url": "={{$env.OPENCLAW_GATEWAY_URL || 'http://openclaw-gateway:18789'}}/api/clients/new",
        "options": {
          "timeout": 10000
        }
      }
    },
    {
      "name": "Для каждого клиента",
      "type": "n8n-nodes-base.splitInBatches",
      "position": [650, 300],
      "parameters": {
        "batchSize": 1
      }
    },
    {
      "name": "Мониторинг Wildberries",
      "type": "n8n-nodes-base.httpRequest",
      "position": [850, 200],
      "parameters": {
        "url": "={{$env.WEBHOOK_URL || 'http://ultimate-agent-api:3000'}}/api/monitor/wildberries",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "clientId",
              "value": "={{$json.clientId}}"
            },
            {
              "name": "articles",
              "value": "={{$json.articles}}"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      }
    },
    {
      "name": "Анализ тональности",
      "type": "n8n-nodes-openclaw.openClaw",
      "position": [1050, 200],
      "parameters": {
        "gatewayUrl": "={{$env.OPENCLAW_GATEWAY_URL || 'http://openclaw-gateway:18789'}}",
        "gatewayToken": "4555d5bd1f5a136439ed7a785251c29e61a5290bd330d7a4",
        "model": "custom-api-deepseek-com/deepseek-chat",
        "prompt": "Проанализируй тональность отзыва: {{$json.reviewText}}\n\nВерни JSON: {\"sentiment\": \"positive/negative/neutral\", \"score\": 0-10, \"issues\": [\"проблема1\", \"проблема2\"], \"recommendations\": [\"рекомендация1\", \"рекомендация2\"]}",
        "inputData": "={{$json.reviews}}"
      }
    },
    {
      "name": "Обновить Google Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "position": [1250, 200],
      "parameters": {
        "operation": "append",
        "sheetId": "={{$json.sheetId}}",
        "range": "Отзывы!A:E",
        "values": {
          "values": [
            [
              "={{new Date().toISOString()}}",
              "={{$json.article}}",
              "={{$json.rating}}",
              "={{$json.sentiment}}",
              "={{JSON.stringify($json.issues)}}"
            ]
          ]
        }
      }
    },
    {
      "name": "Финансовый автопилот",
      "type": "n8n-nodes-base.code",
      "position": [850, 400],
      "parameters": {
        "jsCode": "// Автоматический финансовый учёт\nconst income = Math.random() * 10000 + 5000;\nconst expenses = Math.random() * 7000 + 3000;\nconst profit = income - expenses;\nconst cashFlow = profit > 0 ? 'positive' : 'negative';\n\nreturn {\n  clientId: $json.clientId,\n  date: new Date().toISOString().split('T')[0],\n  income: Math.round(income),\n  expenses: Math.round(expenses),\n  profit: Math.round(profit),\n  cashFlow,\n  alert: profit < 2000 ? 'Низкая маржинальность' : 'OK'\n};"
      }
    },
    {
      "name": "Отправить в Telegram",
      "type": "n8n-nodes-base.telegram",
      "position": [1050, 400],
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{$json.telegramChatId}}",
        "text": "={{$json.message}}"
      }
    },
    {
      "name": "Создать отчёт",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1250, 400],
      "parameters": {
        "url": "={{$env.WEBHOOK_URL || 'http://ultimate-agent-api:3000'}}/api/report/daily",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "clientId",
              "value": "={{$json.clientId}}"
            },
            {
              "name": "data",
              "value": "={{$json}}"
            }
          ]
        }
      }
    }
  ],
  "connections": {
    "Когда: Новый клиент": {
      "main": [
        [
          {
            "node": "Проверить новых клиентов",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Проверить новых клиентов": {
      "main": [
        [
          {
            "node": "Для каждого клиента",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Для каждого клиента": {
      "main": [
        [
          {
            "node": "Мониторинг Wildberries",
            "type": "main",
            "index": 0
          },
          {
            "node": "Финансовый автопилот",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Мониторинг Wildberries": {
      "main": [
        [
          {
            "node": "Анализ тональности",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Анализ тональности": {
      "main": [
        [
          {
            "node": "Обновить Google Sheets",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Финансовый автопилот": {
      "main": [
        [
          {
            "node": "Отправить в Telegram",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Отправить в Telegram": {
      "main": [
        [
          {
            "node": "Создать отчёт",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "pinData": {}
}